# ========== LLM 配置 ==========
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=sk-your-key
LLM_MODEL=deepseek-chat

# ========== MySQL（与 ai-stock 共享） ==========
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=s_ai_agent

# ========== Redis（与 ai-stock 共享） ==========
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_TTL=3600

# ========== AkShare Gateway ==========
AKSHARE_GATEWAY_URL=http://127.0.0.1:5000

# ========== ai-stock 主服务地址（用于查询部分非迁移接口） ==========
AI_STOCK_API_URL=http://127.0.0.1:8000

# ========== Scheduler 服务配置 ==========
SCHEDULER_PORT=8001
LOG_LEVEL=INFO

# ========== 调度模式 ==========
# true=启用自动定时任务  false=仅提供API手动触发
SCHEDULER_AUTO_START=true
